#!/usr/bin/env sh
set -eu

SOURCE=$0
while [ -L "$SOURCE" ]; do
  LINK_DIR=$(CDPATH= cd -P -- "$(dirname -- "$SOURCE")" && pwd)
  SOURCE=$(readlink "$SOURCE")
  case "$SOURCE" in
    /*) ;;
    *) SOURCE="$LINK_DIR/$SOURCE" ;;
  esac
done

DIR=$(CDPATH= cd -P -- "$(dirname -- "$SOURCE")" && pwd)
BIN="$DIR/target/release/games"

if [ -x "$BIN" ]; then
  exec "$BIN"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --release --manifest-path "$DIR/Cargo.toml"
fi

cat >&2 <<EOF
Rust is required to run this version of TUI Arcade.

Install it with:
  brew install rust

Then run:
  games
EOF
exit 1
